# ---- Router (Belong / Sagemcom F@st modem) ----
ROUTER_HOST=10.0.0.138
# Belong/Telstra Sagemcom modems use the LOCAL admin account name below, not "admin".
ROUTER_USERNAME=local_admin
# The modem ADMIN password (often printed on the sticker on the modem),
# NOT your wifi password.
ROUTER_PASSWORD=

# ---- Supabase (filled in during Phase 2/3) ----
SUPABASE_URL=
# Use the service_role key here — this agent runs on your own machine, never ships to the browser.
SUPABASE_SERVICE_KEY=

# How often to poll the router, in seconds (Phase 3 collector).
POLL_INTERVAL_SECONDS=60
