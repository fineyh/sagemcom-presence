# Supabase (server-side only — never exposed to the browser)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Dashboard password gate
DASHBOARD_PASSWORD=choose-a-password
# Optional: extra secret mixed into the session cookie hash. Defaults to the
# password if unset. Set to any random string for a bit more strength.
AUTH_SECRET=
